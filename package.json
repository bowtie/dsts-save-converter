{
  "name": "dsts-save-converter",
  "version": "1.0.0",
  "description": "Browser-based save converter for Digimon Story: Time Stranger (PC ↔ Nintendo Switch)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "verify": "vp check && bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/crypto-js": "4.2.2",
    "typescript": "^5.4.0",
    "vite-plus": "0.2.4"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}
